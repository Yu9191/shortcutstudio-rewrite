#!name=Shortcut
#!desc=修改 ShortcutStudio generate 请求模型参数与设备安装 ID
#!author=ios151
#!homepage=https://github.com/Yu9191/shortcutstudio-rewrite
#!category=快捷指令
#!arguments=思考模式:auto, 搜索模式:off, 设备ID复用次数:2, sign接口替换:off, limits响应mock:off, 消息额度:999, 下载额度:999, 搜索额度:999, 上传额度:999, 市场下载额度:999, 输入字数:20000, 日志级别:info
#!arguments-desc=思考模式: auto/on/off\n搜索模式: auto/on/off\n设备ID复用次数: 默认2次后切换\nsign接口替换: off=不替换/sign设备ID，减少对签名/隐私敏感请求影响; on=对/sign也替换设备ID\nlimits响应mock: off=不修改/users/me/limits响应; on=仅修改本机App看到的UI显示额度，不改变服务端真实额度\n消息/下载/搜索/上传/市场下载额度与输入字数: limits响应mock=on时生效\n日志级别: off/error/warn/info/debug/all

[Script]
ShortcutStudio Generate = type=http-request, pattern="^https:\/\/api\.shortcutstudio\.app\/generate(?:[/?#]|$)", requires-body=1, max-size=0, timeout=30, script-path=https://raw.githubusercontent.com/Yu9191/shortcutstudio-rewrite/refs/heads/baby/dist/request.js, argument=thinkingMode={{{思考模式}}}&searchWebMode={{{搜索模式}}}&deviceIdReuseLimit={{{设备ID复用次数}}}&signRewrite={{{sign接口替换}}}&logLevel={{{日志级别}}}
ShortcutStudio Limits = type=http-request, pattern="^https:\/\/api\.shortcutstudio\.app\/users\/me\/limits(?:[/?#]|$)", requires-body=0, max-size=0, timeout=30, script-path=https://raw.githubusercontent.com/Yu9191/shortcutstudio-rewrite/refs/heads/baby/dist/request.js, argument=thinkingMode={{{思考模式}}}&searchWebMode={{{搜索模式}}}&deviceIdReuseLimit={{{设备ID复用次数}}}&signRewrite={{{sign接口替换}}}&logLevel={{{日志级别}}}
ShortcutStudio Sign = type=http-request, pattern="^https:\/\/api\.shortcutstudio\.app\/sign(?:[/?#]|$)", requires-body=0, max-size=0, timeout=30, script-path=https://raw.githubusercontent.com/Yu9191/shortcutstudio-rewrite/refs/heads/baby/dist/request.js, argument=thinkingMode={{{思考模式}}}&searchWebMode={{{搜索模式}}}&deviceIdReuseLimit={{{设备ID复用次数}}}&signRewrite={{{sign接口替换}}}&logLevel={{{日志级别}}}
ShortcutStudio Limits Mock = type=http-response, pattern="^https:\/\/api\.shortcutstudio\.app\/users\/me\/limits(?:[/?#]|$)", requires-body=1, max-size=0, timeout=30, script-path=https://raw.githubusercontent.com/Yu9191/shortcutstudio-rewrite/refs/heads/baby/dist/response.js, argument=limitsMock={{{limits响应mock}}}&messagesLimit={{{消息额度}}}&downloadsLimit={{{下载额度}}}&searchesLimit={{{搜索额度}}}&uploadsLimit={{{上传额度}}}&marketplaceDownloadsLimit={{{市场下载额度}}}&chatInputCharsLimit={{{输入字数}}}&logLevel={{{日志级别}}}

[MITM]
hostname = %APPEND% api.shortcutstudio.app
